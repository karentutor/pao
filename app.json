{
  "expo": {
    "name": "pao",
    "slug": "pao",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/pao.png",
    "userInterfaceStyle": "light",
    "scheme": "pao",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/pao.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.karentutor1.pao",
     "infoPlist": {
       "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to use the microphone for voice commands.",
       "NSSpeechRecognitionUsageDescription": "Allow $(PRODUCT_NAME) to use speech recognition to navigate the app.",
       "ITSAppUsesNonExemptEncryption": false
     }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.karentutor1.pao"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "945d7947-48fe-48ca-9034-868aacd6d399"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to use the microphone.",
          "speechRecognitionPermission": "Allow $(PRODUCT_NAME) to use speech recognition.",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
        }
      ]
    ]
  }
}
